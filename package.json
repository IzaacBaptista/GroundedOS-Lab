{
  "name": "groundedos-lab",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first open-source lab for building, studying, and evaluating grounded AI systems.",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "api:dev": "tsx apps/api/src/server.ts",
    "build": "npm run typecheck",
    "ingest:smoke": "tsx scripts/ingest-smoke.ts",
    "rag:ask": "tsx scripts/rag-ask.ts",
    "rag:smoke": "tsx scripts/rag-smoke.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
