{
  "name": "groundedos-lab",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first open-source lab for building, studying, and evaluating grounded AI systems.",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "api:dev": "tsx apps/api/src/server.ts",
    "api:jobs:worker": "npm --workspace @groundedos/api run jobs:worker",
    "benchmark:hybrid": "tsx scripts/benchmark-hybrid-retrieval.ts",
    "benchmark:drift": "tsx scripts/detect-corpus-drift.ts",
    "benchmark:retrieval:backends": "tsx scripts/benchmark-retrieval-backends.ts",
    "benchmark:providers": "tsx scripts/benchmark-model-providers.ts --providers local-extractive --output /tmp/groundedos-benchmark-providers.json",
    "benchmark:models": "tsx scripts/benchmark-model-providers.ts",
    "benchmark:models:precheck": "tsx scripts/benchmark-models-precheck.ts",
    "build": "npm run typecheck",
    "build:api": "tsc -p apps/api/tsconfig.json",
    "build:web": "npm --workspace @groundedos/web run build",
    "experiment:prompts": "tsx scripts/ab-test-prompts.ts",
    "experiment:prompts:diff": "tsx scripts/prompt-policy-diff.ts",
    "experiment:phase5": "npm run experiment:fine-tuning && npm run experiment:lora && npm run experiment:quantization && npm run experiment:distillation",
    "experiment:fine-tuning": "PYTHONDONTWRITEBYTECODE=1 python3 experiments/fine-tuning/run_experiment.py",
    "experiment:lora": "PYTHONDONTWRITEBYTECODE=1 python3 experiments/lora/run_experiment.py",
    "experiment:lora:real": "PYTHONDONTWRITEBYTECODE=1 /tmp/groundedos-ml/bin/python3 experiments/lora/run_experiment_real.py",
    "experiment:fine-tuning:real": "PYTHONDONTWRITEBYTECODE=1 /tmp/groundedos-ml/bin/python3 experiments/fine-tuning/run_experiment_real.py",
    "experiment:distillation:real": "PYTHONDONTWRITEBYTECODE=1 /tmp/groundedos-ml/bin/python3 experiments/distillation/run_experiment_real.py",
    "experiment:quantization": "PYTHONDONTWRITEBYTECODE=1 python3 experiments/quantization/run_experiment.py",
    "experiment:distillation": "PYTHONDONTWRITEBYTECODE=1 python3 experiments/distillation/run_experiment.py",
    "ingest:smoke": "tsx scripts/ingest-smoke.ts",
    "instructions:check": "tsx scripts/check-instruction-layer.ts",
    "instructions:deprecations": "tsx scripts/report-instruction-deprecations.ts",
    "instructions:references": "tsx scripts/validate-instruction-references.ts",
    "instructions:migrate:apply": "tsx scripts/apply-instruction-schema-migration.ts",
    "instructions:migrate:plan": "tsx scripts/plan-instruction-schema-migration.ts",
    "instructions:resolve": "tsx scripts/resolve-instruction-layer.ts",
    "instructions:validate": "tsx scripts/validate-instruction-layer.ts",
    "rag:ask": "tsx scripts/rag-ask.ts",
    "rag:replay": "tsx scripts/replay-rag-query.ts",
    "rag:smoke": "tsx scripts/rag-smoke.ts",
    "eval:harness": "tsx scripts/eval-harness.ts",
    "test": "vitest run",
    "test:harness": "vitest run packages/test-harness/src",
    "test:rag": "vitest run packages/rag/src packages/test-harness/src/rag/index.test.ts",
    "test:providers": "vitest run packages/test-harness/src/providers/index.test.ts",
    "test:agents": "vitest run packages/agents/src/agent.test.ts packages/test-harness/src/agents/index.test.ts",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "web:dev": "npm --workspace @groundedos/web run dev"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@swc/core": "^1.9.3",
    "@types/node": "^22.10.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "unplugin-swc": "^1.5.1",
    "vitest": "^2.1.8",
    "yaml": "^2.8.4"
  }
}
