# Reference environment file for the local GroundedOS API.
# This project currently reads process environment variables directly.
# Copy the values you need into your shell, task runner, or local env loader.

# API server port
PORT=3001

# Node environment
NODE_ENV=development

# === Phase 6: Database Configuration (PostgreSQL) ===

# Full connection URL (overrides individual settings below)
DATABASE_URL=postgresql://groundedos:groundedos-dev-password@localhost:5432/groundedos

# Individual settings (used if DATABASE_URL not set)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=groundedos
POSTGRES_USER=groundedos
POSTGRES_PASSWORD=groundedos-dev-password

# === Phase 6: Queue Configuration (Redis) ===

# Full Redis connection URL
REDIS_URL=redis://:groundedos-dev-password@localhost:6379

# Individual settings (used if REDIS_URL not set)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=groundedos-dev-password
REDIS_DB=0

# === Phase 6: Authentication & Authorization ===

# JWT configuration (Bearer token for API/CLI access)
JWT_SECRET=dev-secret-change-in-production-immediately
JWT_EXPIRY=24h

# Session configuration (Cookies for web UI access)
SESSION_SECRET=dev-session-secret-change-in-production-immediately
SESSION_MAX_AGE=604800000

# Enable authentication middleware for all protected endpoints.
# Keep false until the web app login flow is enabled.
AUTH_ENFORCEMENT=false

# Admin credentials for initial setup (local dev only)
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin-password

# Allowed roles for Lab Mode access (comma-separated)
ALLOWED_LAB_ROLES=user,admin,power-user

# Force HTTPS for session cookies (disable for localhost dev)
FORCE_HTTPS=false

# === RAG Pipeline Configuration ===

# Persisted indexes directory
GROUNDEDOS_INDEX_DIR=.groundedos/indexes

# Session memory directory
GROUNDEDOS_MEMORY_DIR=.groundedos/memory/sessions

# === Phase 3/4: Text Generation (Optional) ===

# Local Ollama setup for generation and embeddings
GROUNDEDOS_OLLAMA_BASE_URL=http://localhost:11434
GROUNDEDOS_OLLAMA_EMBED_MODEL=embeddinggemma
GROUNDEDOS_OLLAMA_EMBED_DIMENSIONS=768
GROUNDEDOS_OLLAMA_GENERATE_MODEL=qwen2.5:0.5b
GROUNDEDOS_OLLAMA_KEEP_ALIVE=5m
GROUNDEDOS_OLLAMA_REQUEST_TIMEOUT_MS=30000

# Cloud LLM providers (optional, for Phase 4 benchmarking)
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.1-8b-instant

# === Observability & Logging (Phase 6) ===

# Log level: trace, debug, info, warn, error
LOG_LEVEL=debug

# OpenTelemetry collector endpoint (optional, Phase 6+)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# === Rate Limiting (Phase 6.2) ===

# Requests per hour per user
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# === Advanced Tuning ===

# Request timeout for external API calls
REQUEST_TIMEOUT_MS=30000

# Max body size for document uploads
MAX_UPLOAD_SIZE=100mb
