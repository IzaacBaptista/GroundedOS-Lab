# Reference environment file for the local GroundedOS API.
# This project currently reads process environment variables directly.
# Copy the values you need into your shell, task runner, or local env loader.

# API server port
PORT=3001

# Optional custom directory for persisted local indexes
GROUNDEDOS_INDEX_DIR=.groundedos/indexes

# Optional Ollama configuration for embeddingProvider="ollama"
GROUNDEDOS_OLLAMA_BASE_URL=http://localhost:11434
GROUNDEDOS_OLLAMA_EMBED_MODEL=embeddinggemma
GROUNDEDOS_OLLAMA_EMBED_DIMENSIONS=768

# Optional advanced tuning
# GROUNDEDOS_OLLAMA_KEEP_ALIVE=5m
# GROUNDEDOS_OLLAMA_REQUEST_TIMEOUT_MS=30000
