# Reference environment file for the local GroundedOS web server.
# This project currently reads process environment variables directly.
# Copy the values you need into your shell, task runner, or local env loader.

# Web server port
PORT=3000

# Local API target used by the /api/* proxy
API_BASE_URL=http://localhost:3001

# Authentication (Phase 6)
VITE_JWT_EXPIRY_MINUTES=1440
VITE_SESSION_ENABLED=true
VITE_LAB_MODE_ENABLED=true

# Optional: Show debug info in console
VITE_DEBUG=false
