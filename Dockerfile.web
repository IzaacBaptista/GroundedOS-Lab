# Dockerfile for GroundedOS Lab Web (Phase 6 local stack)

FROM node:20-alpine

WORKDIR /app

ENV NODE_ENV=development

COPY package.json package-lock.json tsconfig.json ./
COPY apps ./apps
COPY packages ./packages
COPY scripts ./scripts

RUN npm ci

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD node -e "require('http').get('http://localhost:3000', (r) => {if (r.statusCode >= 500) process.exit(1)}).on('error', () => process.exit(1))"

CMD ["npm", "--workspace", "@groundedos/web", "run", "dev", "--", "--host", "0.0.0.0", "--port", "3000"]
