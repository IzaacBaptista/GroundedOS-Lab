# GroundedOS Lab local environment reference.
# Copy this file to `.env` at the repository root for local CLI, benchmark and
# API commands. Real `.env` files are intentionally ignored by git.

# Web dev server proxy target. The Vite app can also use apps/web/.env.
API_BASE_URL=http://localhost:3001

# Local persisted storage
GROUNDEDOS_INDEX_DIR=.groundedos/indexes
GROUNDEDOS_MEMORY_DIR=.groundedos/memory/sessions

# Ollama embeddings for API provider embeddingProvider="ollama"
GROUNDEDOS_OLLAMA_BASE_URL=http://localhost:11434
GROUNDEDOS_OLLAMA_EMBED_MODEL=embeddinggemma
GROUNDEDOS_OLLAMA_EMBED_DIMENSIONS=768

# Phase 4 benchmark local generation provider
GROUNDEDOS_OLLAMA_GENERATE_MODEL=qwen2.5:0.5b

# Phase 4 benchmark cloud provider
# OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
# GROUNDEDOS_OPENAI_INPUT_COST_PER_1K=0
# GROUNDEDOS_OPENAI_OUTPUT_COST_PER_1K=0
