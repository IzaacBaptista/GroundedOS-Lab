# GroundedOS Lab — Docker Compose & Phase 6 Infrastructure Configuration
# 
# Copy this file to `.env` at the root for docker-compose and infrastructure setup.

# === Environment ===
NODE_ENV=development
LOG_LEVEL=debug

# === Phase 6: Infrastructure Ports ===

API_PORT=3001
WEB_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379

# === PostgreSQL Configuration ===

POSTGRES_DB=groundedos
POSTGRES_USER=groundedos
POSTGRES_PASSWORD=groundedos-dev-password-change-in-production

# === Redis Configuration ===

REDIS_PASSWORD=groundedos-dev-password-change-in-production

# === Node.js API Configuration ===

PORT=3001

# === Phase 6: Authentication & Sessions ===

JWT_SECRET=dev-secret-change-in-production-immediately
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=30d
SESSION_SECRET=dev-session-secret-change-in-production-immediately
FORCE_HTTPS=false
# AUTH_ENFORCEMENT=true
# Defaults to true when NODE_ENV is not "development" or "test".
# Uncomment (and set to true) for non-development deployments, or leave
# commented out to rely on the NODE_ENV-based default.

# === Lab Features ===

ALLOWED_LAB_ROLES=user,admin,power-user
VITE_LAB_MODE_ENABLED=true

# === RAG Config ===

GROUNDEDOS_INDEX_DIR=.groundedos/indexes
GROUNDEDOS_MEMORY_DIR=.groundedos/memory/sessions
VECTOR_BACKEND=memory
# VECTOR_DUAL_WRITE=false
# QDRANT_URL=http://localhost:6333
# QDRANT_COLLECTION=rag_chunks
# QDRANT_API_KEY=
# QDRANT_TIMEOUT_MS=5000

# === Optional: Ollama Local LLM ===

GROUNDEDOS_OLLAMA_BASE_URL=http://localhost:11434
GROUNDEDOS_OLLAMA_EMBED_MODEL=embeddinggemma
GROUNDEDOS_OLLAMA_EMBED_DIMENSIONS=768
GROUNDEDOS_OLLAMA_GENERATE_MODEL=qwen2.5:0.5b

# === Optional: Cloud Providers ===

OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.1-8b-instant

# === Rate Limiting (Phase 6.2) ===

RATE_LIMIT_REQUESTS_PER_HOUR=1000

# === Web App ===

VITE_API_BASE_URL=http://localhost:3001
VITE_DEBUG=false
