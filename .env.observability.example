# Observability Stack Configuration (.env.observability)
# 
# Copy this file and customize for your environment:
#   cp .env.observability.example .env.observability
#   source .env.observability
#   docker-compose --profile observability up -d

# ============================================================================
# OpenTelemetry Exporter Configuration
# ============================================================================

# Enable trace/metric export to the observability stack
OTEL_EXPORT_ENABLED=true

# OpenTelemetry Collector endpoint (OTLP over HTTP)
# For Docker Compose: http://otelcol:4318
# For local development: http://localhost:4318
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Service name for traces (overrides default)
OTEL_SERVICE_NAME=groundedos

# Sampling rate (1.0 = export all traces, 0.1 = sample 10%, 0 = disable sampling)
OTEL_TRACES_SAMPLER=always_on

# ============================================================================
# Jaeger Configuration
# ============================================================================

# Jaeger UI URL (for dashboard links in spans)
JAEGER_UI_URL=http://localhost:16686

# Jaeger collector gRPC endpoint (for trace export via gRPC, optional)
# JAEGER_COLLECTOR_ENDPOINT=http://localhost:14317

# ============================================================================
# Prometheus Configuration
# ============================================================================

# Prometheus scrape interval (default: 15s)
PROMETHEUS_SCRAPE_INTERVAL=15s

# Prometheus data retention (default: 15d)
PROMETHEUS_RETENTION=15d

# Prometheus query timeout (default: 2m)
PROMETHEUS_QUERY_TIMEOUT=2m

# ============================================================================
# Grafana Configuration
# ============================================================================

# Grafana admin credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Grafana session cookie secret (change in production)
GF_SESSION_SECRET=GroundedOS-Lab-dev-secret

# Grafana plugins to install (comma-separated)
GF_INSTALL_PLUGINS=grafana-clock-panel,grafana-simple-json-datasource

# ============================================================================
# Application Trace Configuration
# ============================================================================

# API service trace exporting
API_OTEL_EXPORT_ENABLED=true
API_OTEL_EXPORTER_OTLP_ENDPOINT=http://otelcol:4318

# Worker service trace exporting
WORKER_OTEL_EXPORT_ENABLED=true
WORKER_OTEL_EXPORTER_OTLP_ENDPOINT=http://otelcol:4318

# ============================================================================
# Docker Compose Profiling
# ============================================================================

# Set to "observability" to start observability services
# Usage: docker-compose --profile observability up -d
COMPOSE_PROFILES=observability
